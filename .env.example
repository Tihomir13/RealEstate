# Copy to `.env` (gitignored) and fill in. Loaded by src/server.ts via
# Node's built-in process.loadEnvFile() — no dotenv dependency.

# Database driver: sqlite (default, zero setup) | postgres | mongodb
DB_DRIVER=mongodb

# MongoDB Atlas connection string (DB_DRIVER=mongodb)
MONGODB_URI=
# Optional: database name (default: imoti)
#MONGODB_DB=imoti

# PostgreSQL / Supabase (DB_DRIVER=postgres)
#DATABASE_URL=

# SQLite file path override (DB_DRIVER unset/sqlite)
#SQLITE_PATH=

# Server port (default 4000)
#PORT=4000

# Comma-separated production domains for the SSR host guard
#ALLOWED_HOSTS=

# On small instances (e.g. Render free tier, 512MB) cap the V8 heap below the
# container limit so GC kicks in before the OOM killer does (see render.yaml):
#NODE_OPTIONS=--max-old-space-size=256

# NODE_ENV=production refuses to auto-seed an empty database (the in-memory
# seed dataset is an OOM risk on small instances). Override deliberately with:
#SEED_ON_EMPTY=true
